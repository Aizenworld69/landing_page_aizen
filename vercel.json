{
  "buildCommand": "turbo run build --filter=@aizen/frontend",
  "outputDirectory": "apps/frontend/.next",
  "installCommand": "npm install",
  "framework": "nextjs",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://aizen-education-api.onrender.com/api/:path*"
    }
  ]
}
