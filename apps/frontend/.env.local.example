# ─── API Backend ─────────────────────────────────────────────
# Development:
# NEXT_PUBLIC_API_URL=http://127.0.0.1:3001/api

# Production (Render BE URL):
NEXT_PUBLIC_API_URL=https://aizen-education-api.onrender.com/api

# ─── Supabase ─────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ─── Revalidation ────────────────────────────────────────────
# Secret dùng chung với backend để nhận request xóa cache tức thì
# (endpoint /api/revalidate). Phải TRÙNG với REVALIDATE_SECRET bên backend.
REVALIDATE_SECRET=change-me-to-a-random-string
