SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key
JWT_SECRET=your-super-secret-jwt-key
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
# Lark AnyCross webhook URL để nhận thông báo đăng ký mới
LARK_WEBHOOK_URL=https://open-sg.larksuite.com/anycross/trigger/callback/your-token-here
# Secret dùng chung với FE để gọi /api/revalidate — giúp trang public cập nhật
# ngay lập tức khi admin đăng/tắt/sửa/xóa blog, khóa học... Phải TRÙNG với
# REVALIDATE_SECRET bên frontend.
REVALIDATE_SECRET=change-me-to-a-random-string
